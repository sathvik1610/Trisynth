// week9_audit.tri
// Tests Lexical, Parsing, Semantic, IR, Opts, and Backend features based on Week 9 milestones.

// 1. Globals and constants
const int MAX = 100;
int global_count = 0;

// 2. Arrays & Functions
void modify_array(int arr[], int index, int value) {
    arr[index] = value;
}

// 3. Recursion
int factorial(int n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

// 4. Optimization tests (Constant Folding, Strength Reduction, DCE)
void test_optimizations() {
    int x = 2 * 5 + (10 - 10); // Should fold to 10
    int y = x * 4; // Should strength reduce to x << 2 (40)
    int unused = 999; // Should be removed by DCE

    print(y); // Output: 40
}

// 5. Control Flow & Logical Operators
void test_control_flow() {
    bool a = true;
    bool b = false;
    
    // Logical short-circuit 
    if (a || b) {
        print(1); // Output: 1
    }
    
    if (a && b) {
        print(0); // Should not print
    } else {
        print(2); // Output: 2
    }
    
    // Loops and break/continue
    int sum = 0;
    for (int i = 0; i < 5; ++i) {
        if (i == 2) {
            continue;
        }
        if (i == 4) {
            break;
        }
        sum = sum + i; // i=0, 1, 3. Sum = 4
    }
    print(sum); // Output: 4
}

void main() {
    test_optimizations();
    test_control_flow();
    
    int my_array[3];
    modify_array(my_array, 2, 88);
    print(my_array[2]); // Output: 88
    
    int f = factorial(5);
    print(f); // Output: 120
}
