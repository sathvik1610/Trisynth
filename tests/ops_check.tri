// ============================================================
// ops_check.tri  — verify every operation in OPERATIONS.md
// ============================================================

// --- Section 11: helper functions (declared first) ---

int add(int a, int b) {
    return a + b;
}

int factorial(int n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}

int power(int base, int exp) {
    if (exp <= 0) { return 1; }
    return base * power(base, exp - 1);
}

void double_all(int arr[], int size) {
    int i = 0;
    while (i < size) {
        arr[i] = arr[i] * 2;
        ++i;
    }
}

int get_elem(int arr[], int idx) {
    return arr[idx];
}

// ============================================================
void main() {

    // === 1. Arithmetic ===
    int a = 20 + 5;    // 25
    int b = 20 - 5;    // 15
    int c = 20 * 5;    // 100
    int d = 20 / 5;    // 4
    int e = 20 % 6;    // 2
    int f = -7;        // -7
    print(a); print(b); print(c); print(d); print(e); print(f);

    // === 2. Relational ===
    int x = 7;
    if (x == 7)  { print(1); }
    if (x != 3)  { print(1); }
    if (x < 10)  { print(1); }
    if (x > 5)   { print(1); }
    if (x <= 7)  { print(1); }
    if (x >= 7)  { print(1); }

    // === 3. Logical ===
    bool t = true;
    bool fl = false;
    if (t && t)   { print(1); }
    if (t && fl)  { print(0); } else { print(1); }
    if (t || fl)  { print(1); }
    if (fl || fl) { print(0); } else { print(1); }
    if (!fl)      { print(1); }
    if (!t)       { print(0); } else { print(1); }

    // === 4. Strength Reduction (Bitwise shifts via optimizer) ===
    int sr = 3;
    int sa = sr * 4;   // << 2 = 12
    int sb = sr * 8;   // << 3 = 24
    print(sa); print(sb);

    // === 5. Increment / Decrement ===
    int ix = 5;
    ++ix;              // 6
    print(ix);
    --ix; --ix;        // 4
    print(ix);

    // === 6. Assignment ===
    int ax = 10;
    ax = ax + 5;       // 15
    print(ax);
    int arr6[3];
    arr6[0] = 100;
    arr6[1] = arr6[0] + 1;   // 101
    print(arr6[1]);
    const int CAP = 255;
    print(CAP);

    // === 8. if / else ===
    int xe = 7;
    if (xe > 5) { print(1); }
    if (xe == 10) { print(10); } else { print(0); }
    if (xe < 0) { print(-1); } else if (xe == 0) { print(0); } else { print(1); }

    // === 9. while + break/continue ===
    int wi = 0;
    while (wi < 5) { print(wi); ++wi; }
    int wj = 0;
    while (wj < 10) {
        if (wj == 7) { break; }
        if (wj % 2 == 0) { ++wj; continue; }
        print(wj);
        ++wj;
    }

    // === 10. for loop ===
    for (int fi = 0; fi < 5; ++fi) { print(fi); }
    for (int fk = 0; fk < 10; ++fk) {
        if (fk == 5) { break; }
        if (fk == 2) { continue; }
        print(fk);
    }

    // === 11. Functions ===
    int res = add(3, 4);
    print(res);                  // 7
    print(factorial(5));         // 120
    print(power(2, 10));         // 1024

    // === 12. Arrays ===
    int arr12[5];
    arr12[0] = 10;
    arr12[1] = 20;
    int xarr = arr12[0] + arr12[1];
    print(xarr);                 // 30
    int data[3];
    data[0] = 5; data[1] = 10; data[2] = 15;
    double_all(data, 3);
    print(data[0]); print(data[1]); print(data[2]);   // 10 20 30
    int buf[4];
    buf[2] = 99;
    print(get_elem(buf, 2));     // 99

    // === 13. Scoping & const ===
    int xs = 1;
    const int MAX = 500;
    {
        int xs = 2;
        print(xs);     // 2
        print(MAX);    // 500
    }
    print(xs);         // 1
    print(MAX);        // 500

    // === 15. Constant Folding ===
    int cfa = 3 * 4;           // 12
    int cfb = 100 - 50 + 10;   // 60
    int cfc = 2 * 2 * 2 * 2;   // 16
    print(cfa); print(cfb); print(cfc);
}
