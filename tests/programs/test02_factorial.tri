// TEST 02 — Factorial (Recursive)
// Expected output:
//   1! = 1
//   3! = 6
//   5! = 120
//   6! = 720

int factorial(int n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

void main() {
    print(factorial(1));
    print(factorial(3));
    print(factorial(5));
    print(factorial(6));
}
