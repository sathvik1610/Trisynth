// TEST 06 — Arrays passed by reference to functions
// Expected output: 100 200 300

void fill(int arr[], int a, int b, int c) {
    arr[0] = a;
    arr[1] = b;
    arr[2] = c;
}

int sum3(int arr[]) {
    return arr[0] + arr[1] + arr[2];
}

void main() {
    int data[3];
    fill(data, 100, 200, 300);
    print(data[0]);
    print(data[1]);
    print(data[2]);
    /* Also print their sum */
    print(sum3(data));
}
