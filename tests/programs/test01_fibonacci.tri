// TEST 01 — Fibonacci (Recursive)
// Expected output:
//   fib(0) = 0
//   fib(1) = 1
//   fib(2) = 1
//   fib(3) = 2
//   fib(4) = 3
//   fib(5) = 5

int fib(int n) {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    return fib(n - 1) + fib(n - 2);
}

void main() {
    print(fib(0));
    print(fib(1));
    print(fib(2));
    print(fib(3));
    print(fib(4));
    print(fib(5));
}
