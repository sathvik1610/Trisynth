int factorial(int n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

int fibonacci(int n) {
    if (n <= 0) {
        return 0;
    }
    if (n == 1) {
        return 1;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

int gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int power_of_two(int n) {
    int result = 1;
    int i = 0;
    while (i < n) {
        result = result * 2;
        i = i + 1;
    }
    return result;
}

int max(int a, int b) {
    if (a > b) {
        return a;
    }
    return b;
}

int min(int a, int b) {
    if (a < b) {
        return a;
    }
    return b;
}

void main() {

    print(factorial(5));
    print(factorial(7));

    print(fibonacci(8));
    print(fibonacci(10));

    int arr[5];
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    arr[4] = 50;

    int total = 0;
    int i = 0;
    while (i < 5) {
        total = total + arr[i];
        i = i + 1;
    }
    print(total);

    int sarr[5];
    sarr[0] = 5;
    sarr[1] = 3;
    sarr[2] = 1;
    sarr[3] = 4;
    sarr[4] = 2;

    int p = 0;
    while (p < 4) {
        int q = 0;
        while (q < 4 - p) {
            if (sarr[q] > sarr[q + 1]) {
                int tmp = sarr[q];
                sarr[q] = sarr[q + 1];
                sarr[q + 1] = tmp;
            }
            q = q + 1;
        }
        p = p + 1;
    }
    print(sarr[0]);
    print(sarr[1]);
    print(sarr[2]);
    print(sarr[3]);
    print(sarr[4]);

    print(gcd(48, 18));
    print(gcd(100, 75));

    int sum = 0;
    int j = 1;
    while (j <= 10) {
        sum = sum + j;
        j = j + 1;
    }
    print(sum);

    int fsum = 0;
    for (int k = 1; k <= 5; k = k + 1) {
        fsum = fsum + k * k;
    }
    print(fsum);

    int x = 16;
    int sr1 = x * 2;
    int sr2 = x * 4;
    int sr3 = x / 2;
    print(sr1);
    print(sr2);
    print(sr3);

    int a = 6;
    int b = 7;
    int cse1 = a * b + a * b;
    int cse2 = a * b + 10;
    print(cse1);
    print(cse2);

    int cf = (10 * 5) + (20 / 2);
    print(cf);

    print(factorial(gcd(12, 8)));

    print(power_of_two(8));

    print(max(42, 17));
    print(min(42, 17));

    int chain = 3;
    int c1 = chain;
    int c2 = c1;
    int c3 = c2;
    print(c3 * c3);

}
