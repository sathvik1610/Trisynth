// 6. Optimizations: Constant Folding & Strength Reduction
void main() {
    print("Testing Constant Folding:");
    // Constant Folding: 5 * 10 * 2 will be completely evaluated at compile time to 100
    int x = 5 * 10 * 2;
    print(x);

    print("Testing Strength Reduction:");
    int y = 25;
    // Strength Reduction: y * 4 will be converted to y << 2
    int z = y * 4;
    print(z);

    // Another reduction: w / 2 converted to w >> 1
    int w = 100;
    int half = w / 2;
    print(half);
}
