// 4. Array Sum
void main() {
    int data[6];
    data[0] = 10;
    data[1] = 20;
    data[2] = 30;
    data[3] = 40;
    data[4] = 50;
    data[5] = 60;

    int sum = 0;
    for (int i = 0; i < 6; ++i) {
        sum = sum + data[i];
    }

    print("Sum of array elements is:");
    print(sum);
}
