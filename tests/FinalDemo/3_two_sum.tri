// 3. Two Sum
void main() {
    int nums[5];
    nums[0] = 2;
    nums[1] = 7;
    nums[2] = 11;
    nums[3] = 15;
    nums[4] = 3;

    int target = 9;
    int found = 0;

    for (int i = 0; i < 5; ++i) {
        for (int j = i + 1; j < 5; ++j) {
            if (nums[i] + nums[j] == target) {
                print("Found two sum components:");
                print(nums[i]);
                print(nums[j]);
                found = 1;
            }
        }
    }
    if (found == 0) {
        print("Not found");
    }
}
